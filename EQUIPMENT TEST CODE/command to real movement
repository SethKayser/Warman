#include "AccelStepper.h"

#define X_ENABLE_PIN 39
#define X_STEP_PIN 40
#define X_DIR_PIN 41

AccelStepper stepper(3, X_STEP_PIN, X_DIR_PIN);

float steps_per_mm = 25.0;  // change this after calibration

void setup() {
  Serial.begin(9600);

  stepper.setMaxSpeed(800);
  stepper.setAcceleration(2000);
  stepper.setEnablePin(X_ENABLE_PIN);
  stepper.setPinsInverted(false, false, true);
  stepper.enableOutputs();

  stepper.setCurrentPosition(0);

  Serial.println("Stepper calibration test");
}

void loop() {
  moveMM(50);   // move 50 mm forward
  delay(2000);

  moveMM(0);    // return to zero
  delay(2000);
}

void moveMM(float target_mm) {
  long target_steps = target_mm * steps_per_mm;

  Serial.print("Target mm: ");
  Serial.print(target_mm);
  Serial.print(" | Target steps: ");
  Serial.println(target_steps);

  stepper.runToNewPosition(target_steps);
}
