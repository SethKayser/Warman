// Warman-style robotic arm joystick + button stepper control
// Arduino Mega 2560 + UNSW MMDS motor shield

// -------------------- MMDS X slot: Coil motor --------------------
const int COIL_ENABLE_PIN = 39;
const int COIL_STEP_PIN   = 40;
const int COIL_DIR_PIN    = 41;

// -------------------- MMDS Y slot: Extension motor --------------------
const int EXTENSION_ENABLE_PIN = 47;
const int EXTENSION_STEP_PIN   = 48;
const int EXTENSION_DIR_PIN    = 49;

// -------------------- MMDS Z slot: Rotation motor --------------------
const int ROTATION_ENABLE_PIN = 34;
const int ROTATION_STEP_PIN   = 35;
const int ROTATION_DIR_PIN    = 36;

// -------------------- Joystick pins --------------------
const int JOY_X_PIN = A0;
const int JOY_Y_PIN = A1;

#define JOYSTICK_BUTTON_PIN 22
#define EXTRA_BUTTON_PIN    23

// -------------------- D27 zero/home button --------------------
// 2-pin button wiring:
// one side -> D27
// other side -> GND
#define EXTENSION_ZERO_BUTTON_PIN 27

const int EXTRA_BUTTON_PRESSED_STATE = HIGH;

// D27 uses INPUT_PULLUP:
// not pressed = HIGH
// pressed = LOW
const int ZERO_BUTTON_PRESSED_STATE = LOW;

// -------------------- Tuning: deadzones --------------------
int COIL_DEADZONE = 120;
int ROTATION_DEADZONE = 140;

// -------------------- Tuning: step delays --------------------
int EXTENSION_OUT_STEP_DELAY_US = 700;
int EXTENSION_IN_STEP_DELAY_US  = 700;

// -------------------- Hard-coded extension limits --------------------
const long EXTENSION_MIN_POS = 0;

const long EXTENSION_SLOW_START_POS = 2954;
const long EXTENSION_HARD_STOP_POS  = 3600;

// Retract slow zone
const long EXTENSION_RETRACT_SLOW_START_POS = 600;

// Bigger delay = slower
const int EXTENSION_OUT_SLOW_END_DELAY_US = 2500;
const int EXTENSION_IN_SLOW_END_DELAY_US  = 2500;

// Coil motor, X slot
int COIL_UP_SLOW_STEP_DELAY_US   = 6000;
int COIL_UP_FAST_STEP_DELAY_US   = 2200;

int COIL_DOWN_SLOW_STEP_DELAY_US = 7000;
int COIL_DOWN_FAST_STEP_DELAY_US = 2600;

// Rotation motor, Z slot
int ROTATION_LEFT_SLOW_STEP_DELAY_US  = 1500;
int ROTATION_LEFT_FAST_STEP_DELAY_US  = 1000;

int ROTATION_RIGHT_SLOW_STEP_DELAY_US = 1500;
int ROTATION_RIGHT_FAST_STEP_DELAY_US = 1000;

// -------------------- Direction tuning --------------------
const int EXTENSION_OUT_DIR = LOW;
const int EXTENSION_IN_DIR  = HIGH;

const int COIL_UP_DIR   = HIGH;
const int COIL_DOWN_DIR = LOW;

const int ROTATION_LEFT_DIR  = HIGH;
const int ROTATION_RIGHT_DIR = LOW;

bool INVERT_COIL_JOYSTICK = false;
bool INVERT_ROTATION_JOYSTICK = false;

// -------------------- Runtime variables --------------------
int joyXCenter = 512;
int joyYCenter = 512;

unsigned long lastExtensionStepTime = 0;
unsigned long lastCoilStepTime = 0;
unsigned long lastRotationStepTime = 0;

const unsigned long DOUBLE_CLICK_GAP_MS = 350;

bool extraButtonWasPressed = false;
unsigned long lastExtraButtonReleaseTime = 0;
bool currentPressIsExtensionIn = false;

// -------------------- D27 zero button debounce --------------------
bool zeroButtonWasPressed = false;
unsigned long lastZeroButtonClickTime = 0;
const unsigned long ZERO_BUTTON_DEBOUNCE_MS = 250;

// -------------------- Extension step recording --------------------
long extensionStepPosition = 0;
unsigned long extensionStepPulseCount = 0;

bool hardStopReached = false;
bool hardStopPrinted = false;

bool zeroStopReached = false;
bool zeroStopPrinted = false;

enum CoilState {
  COIL_STOP_STATE,
  COIL_UP_STATE,
  COIL_DOWN_STATE
};

enum RotationState {
  ROTATION_STOP_STATE,
  ROTATION_LEFT_STATE,
  ROTATION_RIGHT_STATE
};

void setup() {
  Serial.begin(9600);

  pinMode(COIL_ENABLE_PIN, OUTPUT);
  pinMode(COIL_STEP_PIN, OUTPUT);
  pinMode(COIL_DIR_PIN, OUTPUT);

  pinMode(EXTENSION_ENABLE_PIN, OUTPUT);
  pinMode(EXTENSION_STEP_PIN, OUTPUT);
  pinMode(EXTENSION_DIR_PIN, OUTPUT);

  pinMode(ROTATION_ENABLE_PIN, OUTPUT);
  pinMode(ROTATION_STEP_PIN, OUTPUT);
  pinMode(ROTATION_DIR_PIN, OUTPUT);

  pinMode(JOYSTICK_BUTTON_PIN, INPUT);
  pinMode(EXTRA_BUTTON_PIN, INPUT);

  pinMode(EXTENSION_ZERO_BUTTON_PIN, INPUT_PULLUP);

  digitalWrite(COIL_ENABLE_PIN, LOW);
  digitalWrite(EXTENSION_ENABLE_PIN, LOW);
  digitalWrite(ROTATION_ENABLE_PIN, LOW);

  digitalWrite(COIL_STEP_PIN, LOW);
  digitalWrite(EXTENSION_STEP_PIN, LOW);
  digitalWrite(ROTATION_STEP_PIN, LOW);

  calibrateJoystickCenter();

  Serial.println("READY");
  Serial.println("D27 = set extension position to zero");
  Serial.print("Extend slow start: ");
  Serial.println(EXTENSION_SLOW_START_POS);
  Serial.print("Extend hard stop: ");
  Serial.println(EXTENSION_HARD_STOP_POS);
  Serial.print("Retract slow start: ");
  Serial.println(EXTENSION_RETRACT_SLOW_START_POS);
}

void loop() {
  int joyX = analogRead(JOY_X_PIN);
  int joyY = analogRead(JOY_Y_PIN);

  int coilOffset = joyX - joyXCenter;
  int rotationOffset = joyY - joyYCenter;

  if (INVERT_COIL_JOYSTICK) {
    coilOffset = -coilOffset;
  }

  if (INVERT_ROTATION_JOYSTICK) {
    rotationOffset = -rotationOffset;
  }

  handleZeroButton();
  handleExtensionButton();
  handleCoil(coilOffset);
  handleRotation(rotationOffset);
}

void calibrateJoystickCenter() {
  long xTotal = 0;
  long yTotal = 0;
  const int samples = 100;

  delay(500);

  for (int i = 0; i < samples; i++) {
    xTotal += analogRead(JOY_X_PIN);
    yTotal += analogRead(JOY_Y_PIN);
    delay(5);
  }

  joyXCenter = xTotal / samples;
  joyYCenter = yTotal / samples;
}

// -------------------- D27 zero button --------------------

void handleZeroButton() {
  bool zeroButtonPressed = digitalRead(EXTENSION_ZERO_BUTTON_PIN) == ZERO_BUTTON_PRESSED_STATE;
  unsigned long nowMs = millis();

  if (zeroButtonPressed && !zeroButtonWasPressed && nowMs - lastZeroButtonClickTime > ZERO_BUTTON_DEBOUNCE_MS) {
    extensionStepPosition = 0;
    extensionStepPulseCount = 0;

    hardStopReached = false;
    hardStopPrinted = false;

    zeroStopReached = true;
    zeroStopPrinted = false;

    Serial.println("EXTENSION ZERO SET");
    Serial.print("POSITION: ");
    Serial.println(extensionStepPosition);

    lastZeroButtonClickTime = nowMs;
  }

  zeroButtonWasPressed = zeroButtonPressed;
}

// -------------------- Extension control --------------------

void handleExtensionButton() {
  bool buttonPressed = digitalRead(EXTRA_BUTTON_PIN) == EXTRA_BUTTON_PRESSED_STATE;
  unsigned long nowMs = millis();

  if (buttonPressed && !extraButtonWasPressed) {
    currentPressIsExtensionIn = (nowMs - lastExtraButtonReleaseTime) <= DOUBLE_CLICK_GAP_MS;
  }

  if (!buttonPressed && extraButtonWasPressed) {
    lastExtraButtonReleaseTime = nowMs;
  }

  extraButtonWasPressed = buttonPressed;

  if (!buttonPressed) {
    return;
  }

  if (currentPressIsExtensionIn) {
    if (extensionStepPosition <= EXTENSION_MIN_POS || zeroStopReached) {
      extensionStepPosition = 0;

      if (!zeroStopPrinted) {
        Serial.println("EXTENSION ZERO STOP ACTIVE");
        Serial.print("POSITION: ");
        Serial.println(extensionStepPosition);
        zeroStopPrinted = true;
      }

      return;
    }

    digitalWrite(EXTENSION_DIR_PIN, EXTENSION_IN_DIR);
    stepExtensionMotor(EXTENSION_IN_STEP_DELAY_US, lastExtensionStepTime, -1);
  } else {
    if (extensionStepPosition >= EXTENSION_HARD_STOP_POS || hardStopReached) {
      if (!hardStopPrinted) {
        Serial.println("EXTENSION HARD STOP ACTIVE");
        Serial.print("POSITION: ");
        Serial.println(extensionStepPosition);
        hardStopPrinted = true;
      }
      return;
    }

    digitalWrite(EXTENSION_DIR_PIN, EXTENSION_OUT_DIR);
    stepExtensionMotor(EXTENSION_OUT_STEP_DELAY_US, lastExtensionStepTime, 1);
  }
}

void stepExtensionMotor(int stepDelayUs, unsigned long &lastStepTime, int direction) {
  unsigned long now = micros();

  if (direction > 0 && extensionStepPosition >= EXTENSION_HARD_STOP_POS) {
    hardStopReached = true;

    if (!hardStopPrinted) {
      Serial.println("EXTENSION HARD STOP REACHED");
      Serial.print("FINAL POSITION: ");
      Serial.println(extensionStepPosition);
      hardStopPrinted = true;
    }

    return;
  }

  if (direction < 0 && extensionStepPosition <= EXTENSION_MIN_POS) {
    extensionStepPosition = 0;
    zeroStopReached = true;

    if (!zeroStopPrinted) {
      Serial.println("EXTENSION ZERO STOP REACHED");
      Serial.print("FINAL POSITION: ");
      Serial.println(extensionStepPosition);
      zeroStopPrinted = true;
    }

    return;
  }

  int effectiveDelayUs = stepDelayUs;

  // Slow down near the OUT hard stop
  if (direction > 0 && extensionStepPosition >= EXTENSION_SLOW_START_POS) {
    effectiveDelayUs = map(
      constrain(extensionStepPosition, EXTENSION_SLOW_START_POS, EXTENSION_HARD_STOP_POS),
      EXTENSION_SLOW_START_POS,
      EXTENSION_HARD_STOP_POS,
      EXTENSION_OUT_STEP_DELAY_US,
      EXTENSION_OUT_SLOW_END_DELAY_US
    );
  }

  // Slow down near zero when retracting
  if (direction < 0 && extensionStepPosition <= EXTENSION_RETRACT_SLOW_START_POS) {
    effectiveDelayUs = map(
      constrain(extensionStepPosition, EXTENSION_MIN_POS, EXTENSION_RETRACT_SLOW_START_POS),
      EXTENSION_RETRACT_SLOW_START_POS,
      EXTENSION_MIN_POS,
      EXTENSION_IN_STEP_DELAY_US,
      EXTENSION_IN_SLOW_END_DELAY_US
    );
  }

  if (now - lastStepTime >= (unsigned long)effectiveDelayUs) {
    digitalWrite(EXTENSION_STEP_PIN, HIGH);
    delayMicroseconds(8);
    digitalWrite(EXTENSION_STEP_PIN, LOW);
    lastStepTime = now;

    extensionStepPulseCount++;
    extensionStepPosition += direction;

    if (extensionStepPosition < EXTENSION_MIN_POS) {
      extensionStepPosition = EXTENSION_MIN_POS;
    }

    if (direction > 0) {
      zeroStopReached = false;
      zeroStopPrinted = false;
    }

    if (direction < 0) {
      hardStopReached = false;
      hardStopPrinted = false;
    }

    if (direction > 0 && extensionStepPosition >= EXTENSION_HARD_STOP_POS) {
      hardStopReached = true;

      if (!hardStopPrinted) {
        Serial.println("EXTENSION HARD STOP REACHED");
        Serial.print("FINAL POSITION: ");
        Serial.println(extensionStepPosition);
        hardStopPrinted = true;
      }
    }

    if (direction < 0 && extensionStepPosition <= EXTENSION_MIN_POS) {
      extensionStepPosition = 0;
      zeroStopReached = true;

      if (!zeroStopPrinted) {
        Serial.println("EXTENSION ZERO STOP REACHED");
        Serial.print("FINAL POSITION: ");
        Serial.println(extensionStepPosition);
        zeroStopPrinted = true;
      }
    }
  }
}

// -------------------- Coil control --------------------

void handleCoil(int offset) {
  CoilState state;
  int stepDelay;

  if (offset > COIL_DEADZONE) {
    state = COIL_UP_STATE;
    digitalWrite(COIL_DIR_PIN, COIL_UP_DIR);
    stepDelay = mapConstrainedDelay(abs(offset), COIL_DEADZONE, 512, COIL_UP_SLOW_STEP_DELAY_US, COIL_UP_FAST_STEP_DELAY_US);
  } else if (offset < -COIL_DEADZONE) {
    state = COIL_DOWN_STATE;
    digitalWrite(COIL_DIR_PIN, COIL_DOWN_DIR);
    stepDelay = mapConstrainedDelay(abs(offset), COIL_DEADZONE, 512, COIL_DOWN_SLOW_STEP_DELAY_US, COIL_DOWN_FAST_STEP_DELAY_US);
  } else {
    state = COIL_STOP_STATE;
    stepDelay = 0;
  }

  if (state != COIL_STOP_STATE) {
    stepMotor(COIL_STEP_PIN, stepDelay, lastCoilStepTime);
  }
}

// -------------------- Rotation control --------------------

void handleRotation(int offset) {
  RotationState state;
  int stepDelay;

  if (offset > ROTATION_DEADZONE) {
    state = ROTATION_RIGHT_STATE;
    digitalWrite(ROTATION_DIR_PIN, ROTATION_RIGHT_DIR);
    stepDelay = mapConstrainedDelay(abs(offset), ROTATION_DEADZONE, 512, ROTATION_RIGHT_SLOW_STEP_DELAY_US, ROTATION_RIGHT_FAST_STEP_DELAY_US);
  } else if (offset < -ROTATION_DEADZONE) {
    state = ROTATION_LEFT_STATE;
    digitalWrite(ROTATION_DIR_PIN, ROTATION_LEFT_DIR);
    stepDelay = mapConstrainedDelay(abs(offset), ROTATION_DEADZONE, 512, ROTATION_LEFT_SLOW_STEP_DELAY_US, ROTATION_LEFT_FAST_STEP_DELAY_US);
  } else {
    state = ROTATION_STOP_STATE;
    stepDelay = 0;
  }

  if (state != ROTATION_STOP_STATE) {
    stepMotor(ROTATION_STEP_PIN, stepDelay, lastRotationStepTime);
  }
}

// -------------------- Shared motor functions --------------------

int mapConstrainedDelay(int amount, int deadzone, int maxAmount, int slowDelay, int fastDelay) {
  amount = constrain(amount, deadzone, maxAmount);
  return map(amount, deadzone, maxAmount, slowDelay, fastDelay);
}

void stepMotor(int stepPin, int stepDelayUs, unsigned long &lastStepTime) {
  unsigned long now = micros();

  if (now - lastStepTime >= (unsigned long)stepDelayUs) {
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(8);
    digitalWrite(stepPin, LOW);
    lastStepTime = now;
  }
}
