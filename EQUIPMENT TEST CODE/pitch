// Direct joystick Y control for one stepper
// No input lag, no ramping
// Joystick amount directly controls speed
// LOW = DOWN, HIGH = UP

// =======================
// CHOOSE STEPPER SLOT
// =======================

// X SLOT
#define STEP_ENABLE_PIN 39
#define STEP_PIN        40
#define DIR_PIN         41

// Y SLOT - uncomment these and comment out X above if using Y
// #define STEP_ENABLE_PIN 47
// #define STEP_PIN        48
// #define DIR_PIN         49

// =======================
// JOYSTICK
// =======================

#define JOY_Y_PIN A1

// =======================
// MAIN VARIABLES TO CHANGE
// =======================

const int DIR_DOWN = LOW;
const int DIR_UP   = HIGH;

// Bigger = joystick has to move further before motor starts
int DEADZONE = 140;

// UP SPEED
// Bigger number = slower
int UP_SLOW_STEP_DELAY_US = 14000;   // small joystick push upward
int UP_FAST_STEP_DELAY_US = 5000;    // full joystick push upward

// DOWN SPEED
// Bigger number = slower
int DOWN_SLOW_STEP_DELAY_US = 18000; // small joystick push downward
int DOWN_FAST_STEP_DELAY_US = 9000;  // full joystick push downward

// Change this if joystick direction feels backwards
bool INVERT_JOYSTICK_DIRECTION = false;

// =======================
// INTERNAL
// =======================

int JOY_Y_CENTER = 0;
long stepCount = 0;

unsigned long lastStepMicros = 0;

void setup() {
  Serial.begin(9600);

  pinMode(STEP_ENABLE_PIN, OUTPUT);
  pinMode(STEP_PIN, OUTPUT);
  pinMode(DIR_PIN, OUTPUT);

  digitalWrite(STEP_ENABLE_PIN, LOW);
  digitalWrite(STEP_PIN, LOW);

  // Auto-calibrate joystick centre
  long total = 0;
  for (int i = 0; i < 100; i++) {
    total += analogRead(JOY_Y_PIN);
    delay(5);
  }

  JOY_Y_CENTER = total / 100;

  Serial.println("Direct joystick stepper control ready");
  Serial.print("Joystick centre = ");
  Serial.println(JOY_Y_CENTER);
}

void loop() {
  int joyY = analogRead(JOY_Y_PIN);
  int offset = joyY - JOY_Y_CENTER;
  int absOffset = abs(offset);

  // Stop instantly near centre
  if (absOffset < DEADZONE) {
    return;
  }

  int stepDelay;

  // Joystick one way
  if (offset > 0) {
    if (INVERT_JOYSTICK_DIRECTION == false) {
      digitalWrite(DIR_PIN, DIR_UP);

      stepDelay = map(
        constrain(absOffset, DEADZONE, 512),
        DEADZONE,
        512,
        UP_SLOW_STEP_DELAY_US,
        UP_FAST_STEP_DELAY_US
      );
    } else {
      digitalWrite(DIR_PIN, DIR_DOWN);

      stepDelay = map(
        constrain(absOffset, DEADZONE, 512),
        DEADZONE,
        512,
        DOWN_SLOW_STEP_DELAY_US,
        DOWN_FAST_STEP_DELAY_US
      );
    }
  }

  // Joystick other way
  else {
    if (INVERT_JOYSTICK_DIRECTION == false) {
      digitalWrite(DIR_PIN, DIR_DOWN);

      stepDelay = map(
        constrain(absOffset, DEADZONE, 512),
        DEADZONE,
        512,
        DOWN_SLOW_STEP_DELAY_US,
        DOWN_FAST_STEP_DELAY_US
      );
    } else {
      digitalWrite(DIR_PIN, DIR_UP);

      stepDelay = map(
        constrain(absOffset, DEADZONE, 512),
        DEADZONE,
        512,
        UP_SLOW_STEP_DELAY_US,
        UP_FAST_STEP_DELAY_US
      );
    }
  }

  // Step motor at chosen speed
  unsigned long now = micros();

  if (now - lastStepMicros >= stepDelay) {
    lastStepMicros = now;

    digitalWrite(STEP_PIN, HIGH);
    delayMicroseconds(5);
    digitalWrite(STEP_PIN, LOW);

    stepCount++;
  }

  static unsigned long lastPrint = 0;
  if (millis() - lastPrint > 300) {
    lastPrint = millis();

    Serial.print("Joy Y = ");
    Serial.print(joyY);

    Serial.print(" | Offset = ");
    Serial.print(offset);

    Serial.print(" | Step delay = ");
    Serial.print(stepDelay);

    Serial.print(" | Steps = ");
    Serial.println(stepCount);
  }
}
