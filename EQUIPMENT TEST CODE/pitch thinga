// Change to A1 if using joystick Y axis
#define JOY_AXIS_PIN A0

// =======================
// MAIN VARIABLES TO CHANGE
// =======================

// FIX 1: Hysteresis deadzone
// JOY_DEADZONE_ENTER: joystick must exceed this to START moving
// JOY_DEADZONE_EXIT:  joystick must fall below this to STOP
// The gap between them prevents flickering at the boundary
int JOY_DEADZONE_ENTER = 120;
int JOY_DEADZONE_EXIT  = 60;

// Direction names
const char* NEGATIVE_NAME = "NEMA23 NEGATIVE";
const char* POSITIVE_NAME = "NEMA23 POSITIVE";

// Direction pins
// Swap HIGH/LOW if direction is backwards
const int NEGATIVE_DIR = LOW;
const int POSITIVE_DIR = HIGH;

// FIX 2: Matched negative fast speed to positive (was 3000, caused sluggish retract)
// Bigger number = slower/smoother
// Smaller number = faster
int POSITIVE_SLOW_STEP_DELAY_US = 5000;
int POSITIVE_FAST_STEP_DELAY_US = 1000;

int NEGATIVE_SLOW_STEP_DELAY_US = 10000;
int NEGATIVE_FAST_STEP_DELAY_US = 2000;  // Fixed: was 3000

// FIX 3: Disable enable-pin toggling to prevent motor losing torque on every stop/start
// If ENA is disconnected, set this to false
// Set to false unless you specifically need the motor unpowered at rest
bool USE_ENABLE_PIN = false;

// Try HIGH first.
// If motor does not move, swap HIGH and LOW below.
const int MOTOR_ENABLE_STATE  = HIGH;
const int MOTOR_DISABLE_STATE = LOW;

// If joystick direction feels backwards, change to true
bool INVERT_JOYSTICK = false;

// Pulse width for TB6600
int STEP_PULSE_WIDTH_US = 20;

// =======================
// INTERNAL
// =======================

int JOY_CENTER = 0;
String currentAction = "STOP";
bool isMoving = false;  // FIX 1: tracks motion state for hysteresis

unsigned long lastStepMicros = 0;

void setup() {
  Serial.begin(9600);

  pinMode(V_ENABLE_PIN, OUTPUT);
  pinMode(V_STEP_PIN, OUTPUT);
  pinMode(V_DIR_PIN, OUTPUT);

  digitalWrite(V_STEP_PIN, LOW);
  digitalWrite(V_DIR_PIN, LOW);

  // FIX 3: Enable motor once at startup and leave it on
  if (USE_ENABLE_PIN) {
    digitalWrite(V_ENABLE_PIN, MOTOR_ENABLE_STATE);
  }

  // Auto-calibrate joystick centre
  long total = 0;

  for (int i = 0; i < 100; i++) {
    total += analogRead(JOY_AXIS_PIN);
    delay(5);
  }

  JOY_CENTER = total / 100;

  Serial.println("V slot NEMA23 joystick control ready");
  Serial.print("Joystick centre = ");
  Serial.println(JOY_CENTER);
}

void loop() {
  int joyValue = analogRead(JOY_AXIS_PIN);
  controlV(joyValue);
}

void controlV(int joyValue) {
  int offset = joyValue - JOY_CENTER;
  int absOffset = abs(offset);

  // FIX 1: Hysteresis — use different thresholds for starting vs stopping
  // Once moving, keep moving until offset drops below EXIT threshold
  // When stopped, only start moving if offset exceeds ENTER threshold
  int activeDeadzone = isMoving ? JOY_DEADZONE_EXIT : JOY_DEADZONE_ENTER;

  if (absOffset < activeDeadzone) {
    isMoving = false;

    if (currentAction != "STOP") {
      currentAction = "STOP";
      Serial.println("NEMA23 STOP");
    }

    return;
  }

  isMoving = true;

  int stepDelay;
  String newAction;

  // FIX 2: Use 500 as the map ceiling instead of 512
  // This gives a more accurate full-range map since max offset from centre is ~500
  int mappedOffset = constrain(absOffset, activeDeadzone, 500);

  if (offset > 0) {
    if (INVERT_JOYSTICK == false) {
      digitalWrite(V_DIR_PIN, POSITIVE_DIR);
      newAction = POSITIVE_NAME;
      stepDelay = map(mappedOffset, activeDeadzone, 500, POSITIVE_SLOW_STEP_DELAY_US, POSITIVE_FAST_STEP_DELAY_US);
    } else {
      digitalWrite(V_DIR_PIN, NEGATIVE_DIR);
      newAction = NEGATIVE_NAME;
      stepDelay = map(mappedOffset, activeDeadzone, 500, NEGATIVE_SLOW_STEP_DELAY_US, NEGATIVE_FAST_STEP_DELAY_US);
    }
  } else {
    if (INVERT_JOYSTICK == false) {
      digitalWrite(V_DIR_PIN, NEGATIVE_DIR);
      newAction = NEGATIVE_NAME;
      stepDelay = map(mappedOffset, activeDeadzone, 500, NEGATIVE_SLOW_STEP_DELAY_US, NEGATIVE_FAST_STEP_DELAY_US);
    } else {
      digitalWrite(V_DIR_PIN, POSITIVE_DIR);
      newAction = POSITIVE_NAME;
      stepDelay = map(mappedOffset, activeDeadzone, 500, POSITIVE_SLOW_STEP_DELAY_US, POSITIVE_FAST_STEP_DELAY_US);
    }
  }

  if (newAction != currentAction) {
    currentAction = newAction;
    Serial.println(currentAction);
  }

  unsigned long now = micros();

  if (now - lastStepMicros >= (unsigned long)stepDelay) {
    lastStepMicros = now;

    digitalWrite(V_STEP_PIN, HIGH);
    delayMicroseconds(STEP_PULSE_WIDTH_US);
    digitalWrite(V_STEP_PIN, LOW);
  }
}
