#include <Servo.h>

// =====================================================
// CLICK-TO-ADVANCE FLOW CHART
// Click 1: Servo goes to 30, pitch lowers 250 steps
// Click 2: Extension moves out 470 steps
// Click 3: Servo quickly moves to 40 degrees and locks
// Click 4: Pitch lowers 100 steps
// Click 5: Extension moves out another 700 steps
// Click 6: Servo quickly moves to 85 degrees and locks
// Click 7: Extension moves out another 400 steps
// Click 8: Switch servo off
// Click 9: Pitch lowers 200 steps
// Click 10: Extension moves out 200 steps
// Click 11: Servo on, stays on same step, servo goes up by another 60 degrees and locks
// Click 12: Extension moves out 400 steps
// Click 13: Pitch goes up 300 steps
// Then sequence stops
// =====================================================

const int PITCH_ENABLE_PIN = 42;
const int PITCH_STEP_PIN   = 43;
const int PITCH_DIR_PIN    = 57;

const int EXTENSION_ENABLE_PIN = 34;
const int EXTENSION_STEP_PIN   = 35;
const int EXTENSION_DIR_PIN    = 36;

const int SERVO_PIN = 5;
const int BUTTON_PIN = 22;
const int BUTTON_PRESSED_STATE = HIGH;

const int DRIVER_ENABLED_STATE  = LOW;
const int DRIVER_DISABLED_STATE = HIGH;

const int PITCH_DOWN_DIR = LOW;
const int PITCH_UP_DIR = HIGH;

const int EXTENSION_OUT_DIR = LOW;

const unsigned int PULSE_WIDTH_US = 20;

const unsigned long PITCH_STEP_DELAY_US = 5000;
const unsigned long EXTENSION_STEP_DELAY_US = 1000;

const unsigned long PITCH_DOWN_STEPS = 250;
const unsigned long PITCH_DOWN_SMALL_STEPS = 100;
const unsigned long PITCH_DOWN_FINAL_STEPS = 200;
const unsigned long PITCH_UP_STEPS = 300;

const unsigned long EXTENSION_START_STEPS = 470;
const unsigned long EXTENSION_EXTRA_STEPS = 700;
const unsigned long EXTENSION_FINAL_STEPS = 400;
const unsigned long EXTENSION_AFTER_PITCH_STEPS = 200;
const unsigned long EXTENSION_LAST_STEPS = 400;

const int SERVO_START_ANGLE = 0;
const int SERVO_FIRST_ANGLE = 30;
const int SERVO_SECOND_ANGLE = 40;
const int SERVO_THIRD_ANGLE = 85;
const int SERVO_UP_EXTRA_DEGREES = 60;
const int SERVO_SLOW_DELAY_MS = 12; // faster to reduce twitching

int sequenceStep = 0;
bool sequenceDone = false;
int currentServoAngle = SERVO_START_ANGLE;

Servo scoopServo;

void setup() {
  Serial.begin(9600);

  pinMode(PITCH_ENABLE_PIN, OUTPUT);
  pinMode(PITCH_STEP_PIN, OUTPUT);
  pinMode(PITCH_DIR_PIN, OUTPUT);

  pinMode(EXTENSION_ENABLE_PIN, OUTPUT);
  pinMode(EXTENSION_STEP_PIN, OUTPUT);
  pinMode(EXTENSION_DIR_PIN, OUTPUT);

  pinMode(BUTTON_PIN, INPUT);

  digitalWrite(PITCH_STEP_PIN, LOW);
  digitalWrite(PITCH_ENABLE_PIN, DRIVER_DISABLED_STATE);

  digitalWrite(EXTENSION_STEP_PIN, LOW);
  digitalWrite(EXTENSION_DIR_PIN, EXTENSION_OUT_DIR);
  digitalWrite(EXTENSION_ENABLE_PIN, DRIVER_DISABLED_STATE);

  scoopServo.detach();

  Serial.println("Ready: one action per button press");
}

void loop() {
  if (digitalRead(BUTTON_PIN) == BUTTON_PRESSED_STATE && !sequenceDone) {
    delay(50);

    if (digitalRead(BUTTON_PIN) == BUTTON_PRESSED_STATE) {
      runNextStep();

      while (digitalRead(BUTTON_PIN) == BUTTON_PRESSED_STATE) {
        delay(10);
      }
    }
  }
}

void runNextStep() {
  sequenceStep++;

  Serial.print("RUNNING CLICK ");
  Serial.println(sequenceStep);

  if (sequenceStep == 1) {
    Serial.println("Click 1: Servo goes to 30, pitch lowers 250 steps");
    moveServoToAndLock(SERVO_FIRST_ANGLE);
    movePitch(PITCH_DOWN_DIR, PITCH_DOWN_STEPS);
  } else if (sequenceStep == 2) {
    Serial.println("Click 2: Extension moves out 470 steps");
    moveExtension(EXTENSION_START_STEPS);
  } else if (sequenceStep == 3) {
    Serial.println("Click 3: Servo moves to 40 degrees and locks");
    moveServoFastToAndLock(SERVO_SECOND_ANGLE);
  } else if (sequenceStep == 4) {
    Serial.println("Click 4: Pitch lowers 100 steps");
    movePitch(PITCH_DOWN_DIR, PITCH_DOWN_SMALL_STEPS);
  } else if (sequenceStep == 5) {
    Serial.println("Click 5: Extension moves out another 700 steps");
    moveExtension(EXTENSION_EXTRA_STEPS);
  } else if (sequenceStep == 6) {
    Serial.println("Click 6: Servo moves to 85 degrees and locks");
    moveServoFastToAndLock(SERVO_THIRD_ANGLE);
  } else if (sequenceStep == 7) {
    Serial.println("Click 7: Extension moves out another 400 steps");
    moveExtension(EXTENSION_FINAL_STEPS);
  } else if (sequenceStep == 8) {
    Serial.println("Click 8: Switch servo off");
    scoopServo.detach();
  } else if (sequenceStep == 9) {
    Serial.println("Click 9: Pitch lowers 200 steps");
    movePitch(PITCH_DOWN_DIR, PITCH_DOWN_FINAL_STEPS);
  } else if (sequenceStep == 10) {
    Serial.println("Click 10: Extension moves out 200 steps");
    moveExtension(EXTENSION_AFTER_PITCH_STEPS);
  } else if (sequenceStep == 11) {
    Serial.println("Click 11: Servo on, then servo up 60 and locks");
    lockServoAtCurrentAngle();
    moveServoFastToAndLock(currentServoAngle + SERVO_UP_EXTRA_DEGREES);
  } else if (sequenceStep == 12) {
    Serial.println("Click 12: Extension moves out 400 steps");
    moveExtension(EXTENSION_LAST_STEPS);
  } else if (sequenceStep == 13) {
    Serial.println("Click 13: Pitch goes up 300 steps");
    movePitch(PITCH_UP_DIR, PITCH_UP_STEPS);
    sequenceDone = true;
    Serial.println("SEQUENCE STOPPED");
  }
}

void moveServoToAndLock(int targetAngle) {
  if (targetAngle < 0) targetAngle = 0;
  if (targetAngle > 180) targetAngle = 180;

  scoopServo.attach(SERVO_PIN);
  scoopServo.write(targetAngle);
  currentServoAngle = targetAngle;
  delay(500);
}

void moveServoFastToAndLock(int targetAngle) {
  if (targetAngle < 0) targetAngle = 0;
  if (targetAngle > 180) targetAngle = 180;

  scoopServo.attach(SERVO_PIN);

  if (targetAngle > currentServoAngle) {
    for (int pos = currentServoAngle; pos <= targetAngle; pos++) {
      scoopServo.write(pos);
      delay(SERVO_SLOW_DELAY_MS);
    }
  } else {
    for (int pos = currentServoAngle; pos >= targetAngle; pos--) {
      scoopServo.write(pos);
      delay(SERVO_SLOW_DELAY_MS);
    }
  }

  currentServoAngle = targetAngle;
  scoopServo.write(currentServoAngle);
}

void lockServoAtCurrentAngle() {
  scoopServo.attach(SERVO_PIN);
  scoopServo.write(currentServoAngle);
}

void movePitch(int direction, unsigned long steps) {
  digitalWrite(PITCH_DIR_PIN, direction);
  delay(20);

  digitalWrite(PITCH_ENABLE_PIN, DRIVER_ENABLED_STATE);
  delay(100);

  for (unsigned long i = 0; i < steps; i++) {
    digitalWrite(PITCH_STEP_PIN, HIGH);
    delayMicroseconds(PULSE_WIDTH_US);
    digitalWrite(PITCH_STEP_PIN, LOW);
    delayMicroseconds(PITCH_STEP_DELAY_US);
  }

  digitalWrite(PITCH_STEP_PIN, LOW);
  digitalWrite(PITCH_ENABLE_PIN, DRIVER_DISABLED_STATE);
}

void moveExtension(unsigned long steps) {
  digitalWrite(EXTENSION_DIR_PIN, EXTENSION_OUT_DIR);
  delay(20);

  digitalWrite(EXTENSION_ENABLE_PIN, DRIVER_ENABLED_STATE);
  delay(50);

  for (unsigned long i = 0; i < steps; i++) {
    digitalWrite(EXTENSION_STEP_PIN, HIGH);
    delayMicroseconds(PULSE_WIDTH_US);
    digitalWrite(EXTENSION_STEP_PIN, LOW);
    delayMicroseconds(EXTENSION_STEP_DELAY_US);
  }

  digitalWrite(EXTENSION_STEP_PIN, LOW);
  digitalWrite(EXTENSION_ENABLE_PIN, DRIVER_DISABLED_STATE);
}
