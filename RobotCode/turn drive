// =====================================================
// DRIVE FORWARD 2000, ROTATE 400, EXTEND 1500
// Press button = enable pitch hold, drive forward for 2 seconds,
// rotate left 400 steps, then extend 1500 steps
// =====================================================

// Pitch stepper pins - enabled only, no movement
const int PITCH_ENABLE_PIN = 42;
const int PITCH_STEP_PIN   = 43;
const int PITCH_DIR_PIN    = 57;

// Rotate stepper pins
const int ROTATE_ENABLE_PIN = 16;
const int ROTATE_STEP_PIN   = 17;
const int ROTATE_DIR_PIN    = 37;

// Extension stepper on MMDS Z slot
const int EXTENSION_ENABLE_PIN = 34;
const int EXTENSION_STEP_PIN   = 35;
const int EXTENSION_DIR_PIN    = 36;

// DC drive motor pins
const int M_D = 33;
const int M_S = 46;

// Button
const int BUTTON_PIN = 22;
const int BUTTON_PRESSED_STATE = HIGH;

const int DRIVER_ENABLED_STATE  = LOW;
const int DRIVER_DISABLED_STATE = HIGH;

const int ROTATE_LEFT_DIR = LOW;
const int EXTENSION_OUT_DIR = LOW;
const int DRIVE_FORWARD_DIR = LOW;

const unsigned int PULSE_WIDTH_US = 20;

const unsigned long ROTATE_STEP_DELAY_US = 1500;
const unsigned long EXTENSION_STEP_DELAY_US = 1000;

const unsigned long ROTATE_LEFT_STEPS = 400;
const unsigned long EXTENSION_OUT_STEPS = 1500;

const int DRIVE_SPEED = 180;
const unsigned long DRIVE_TIME_MS = 2000;

bool hasRun = false;

void setup() {
  Serial.begin(9600);

  pinMode(PITCH_ENABLE_PIN, OUTPUT);
  pinMode(PITCH_STEP_PIN, OUTPUT);
  pinMode(PITCH_DIR_PIN, OUTPUT);

  pinMode(ROTATE_ENABLE_PIN, OUTPUT);
  pinMode(ROTATE_STEP_PIN, OUTPUT);
  pinMode(ROTATE_DIR_PIN, OUTPUT);

  pinMode(EXTENSION_ENABLE_PIN, OUTPUT);
  pinMode(EXTENSION_STEP_PIN, OUTPUT);
  pinMode(EXTENSION_DIR_PIN, OUTPUT);

  pinMode(M_D, OUTPUT);
  pinMode(M_S, OUTPUT);

  pinMode(BUTTON_PIN, INPUT);

  digitalWrite(PITCH_STEP_PIN, LOW);
  digitalWrite(PITCH_ENABLE_PIN, DRIVER_DISABLED_STATE);

  digitalWrite(ROTATE_STEP_PIN, LOW);
  digitalWrite(ROTATE_DIR_PIN, ROTATE_LEFT_DIR);
  digitalWrite(ROTATE_ENABLE_PIN, DRIVER_DISABLED_STATE);

  digitalWrite(EXTENSION_STEP_PIN, LOW);
  digitalWrite(EXTENSION_DIR_PIN, EXTENSION_OUT_DIR);
  digitalWrite(EXTENSION_ENABLE_PIN, DRIVER_DISABLED_STATE);

  analogWrite(M_S, 0);

  Serial.println("Ready: press button to run sequence");
}

void loop() {
  if (digitalRead(BUTTON_PIN) == BUTTON_PRESSED_STATE && !hasRun) {
    delay(50);

    if (digitalRead(BUTTON_PIN) == BUTTON_PRESSED_STATE) {
      runSequence();
      hasRun = true;

      while (digitalRead(BUTTON_PIN) == BUTTON_PRESSED_STATE) {
        delay(10);
      }
    }
  }
}

void runSequence() {
  Serial.println("ENABLE PITCH HOLD ONLY");
  digitalWrite(PITCH_ENABLE_PIN, DRIVER_ENABLED_STATE);

  delay(500);

  Serial.println("DRIVE FORWARD 2000 MS");
  driveForwardForTime();

  delay(500);

  Serial.println("ROTATE LEFT 400");
  moveStepper(ROTATE_ENABLE_PIN, ROTATE_STEP_PIN, ROTATE_DIR_PIN, ROTATE_LEFT_DIR, ROTATE_LEFT_STEPS, ROTATE_STEP_DELAY_US);

  delay(500);

  Serial.println("EXTEND 1500");
  moveStepper(EXTENSION_ENABLE_PIN, EXTENSION_STEP_PIN, EXTENSION_DIR_PIN, EXTENSION_OUT_DIR, EXTENSION_OUT_STEPS, EXTENSION_STEP_DELAY_US);

  Serial.println("DONE");
}

void moveStepper(
  int enablePin,
  int stepPin,
  int dirPin,
  int direction,
  unsigned long steps,
  unsigned long stepDelayUs
) {
  digitalWrite(dirPin, direction);
  delay(20);

  digitalWrite(enablePin, DRIVER_ENABLED_STATE);
  delay(100);

  for (unsigned long i = 0; i < steps; i++) {
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(PULSE_WIDTH_US);
    digitalWrite(stepPin, LOW);
    delayMicroseconds(stepDelayUs);
  }

  digitalWrite(stepPin, LOW);
  digitalWrite(enablePin, DRIVER_DISABLED_STATE);
}

void driveForwardForTime() {
  digitalWrite(M_D, DRIVE_FORWARD_DIR);
  analogWrite(M_S, DRIVE_SPEED);

  delay(DRIVE_TIME_MS);

  analogWrite(M_S, 0);
}
